STORAGE_DIR=storage
DATABASE_URL=sqlite+aiosqlite:///storage/meme-mcp.db
IMAGE_STORE_BACKEND=filesystem
IMAGE_STORE_FS_PATH=storage/images
GITHUB_CLIENT_ID=dev-client-id
GITHUB_CLIENT_SECRET=dev-client-secret-please-change
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback
GITHUB_ALLOWLIST_PATH=storage/allowlist.txt
OPERATOR_GITHUB_LOGIN=operator
SESSION_SECRET=dev-session-secret-please-change-32-chars
PAT_HASH_PEPPER=dev-pat-pepper-please-change-32-chars
VLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
VLM_API_KEY=dev-vlm-key
VLM_MODEL=gemini-2.5-flash
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=dev-openai-key
EMBEDDING_MODEL=text-embedding-3-small
# Match the dimensionality of EMBEDDING_MODEL: 1536 for OpenAI text-embedding-3-small,
# 768 for EmbeddingGemma 300M, etc. Reindex after changing.
EMBEDDING_DIMENSIONS=1536
MCP_HOST=127.0.0.1
MCP_PORT=8000

