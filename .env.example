STORAGE_DIR=storage
DATABASE_URL=sqlite+aiosqlite:///storage/meme-mcp.db
IMAGE_STORE_BACKEND=filesystem
IMAGE_STORE_FS_PATH=storage/images
# Render-output retention (days): drives the gc-renders sweep AND bounds the
# signed render-URL TTL below. Default 30.
RENDER_GC_TTL_DAYS=30
# TTL for the signed token on generated render URLs. Startup refuses a value
# above RENDER_GC_TTL_DAYS so a live URL never outlives its blob. Default 7 days.
RENDER_URL_TTL_SECONDS=604800
GITHUB_CLIENT_ID=dev-client-id
GITHUB_CLIENT_SECRET=dev-client-secret-please-change
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback
GITHUB_ALLOWLIST_PATH=storage/allowlist.txt
OPERATOR_GITHUB_LOGIN=operator
# Canonical externally visible base URL (scheme://host[:port], no path). Optional:
# when unset it is derived from GITHUB_REDIRECT_URI by stripping /auth/callback.
# Set it when running multiple OAuth providers so the advertised origin does not
# depend on a single provider's redirect URI. WARNING: this origin signs render
# URLs -- changing it invalidates outstanding/bookmarked signed render URLs, and
# startup refuses to boot if it conflicts with GITHUB_REDIRECT_URI's origin.
PUBLIC_BASE_URL=
SESSION_SECRET=dev-session-secret-please-change-32-chars
PAT_HASH_PEPPER=dev-pat-pepper-please-change-32-chars
VLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
VLM_API_KEY=dev-vlm-key
VLM_MODEL=gemini-2.5-flash
# Reverse-image meme enrichment (optional, OFF by default). When enabled, the
# upload pipeline can send EXIF-stripped image bytes to Google Cloud Vision Web
# Detection to recover a meme's web identity before the VLM fills metadata. This
# is the first egress of uploaded images beyond the VLM provider -- the web-form
# toggle defaults ON, PAT clients opt in per request. RE-VERIFY Google's
# no-retention / no-training data terms before provisioning credentials, and use
# a Vision-only least-privilege service account. See docs/ARCHITECTURE.md.
REVERSE_IMAGE_ENABLED=false
# Path to the Vision service-account JSON (the file is the secret; keep it 0600
# and out of version control). Required only when REVERSE_IMAGE_ENABLED=true.
GOOGLE_VISION_CREDENTIALS_PATH=
# Google OAuth sign-in (optional second provider, OFF by default). When enabled,
# non-GitHub friends can sign in with a Google account. Provision a Google Cloud
# "Web application" OAuth client; set the authorized redirect URI to
# <PUBLIC_BASE_URL or GITHUB origin>/auth/google/callback and request the
# "openid email" scopes on the consent screen. All three values below are
# required only when GOOGLE_OAUTH_ENABLED=true. See docs/ARCHITECTURE.md.
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Default: local Ollama OpenAI-compatible endpoint with qwen3-embedding:0.6b
# (multilingual, covers zh-TW). Pull it once: `ollama pull qwen3-embedding:0.6b`.
# A non-empty API key is required even though Ollama ignores it.
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=qwen3-embedding:0.6b
# Match the dimensionality of EMBEDDING_MODEL: 1024 for qwen3-embedding:0.6b,
# 1536 for OpenAI text-embedding-3-small, 768 for EmbeddingGemma 300M, etc.
# Run `meme-mcp reindex-embeddings --force` after changing the model or dimensions.
EMBEDDING_DIMENSIONS=1024
MCP_HOST=127.0.0.1
MCP_PORT=8000
# Per-user hourly cap on self-service PAT generate/regenerate/revoke at /account.
RATE_PAT_ADMIN_PER_HOUR=10
# Path to the JSONL audit log. Defaults to <STORAGE_DIR>/audit.jsonl when unset.
# The sink writes 0600, rotates at 100 MB, and never records token plaintext or hashes.
AUDIT_LOG_PATH=

